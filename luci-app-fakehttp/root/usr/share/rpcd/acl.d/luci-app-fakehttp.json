{
	"luci-app-fakehttp": {
		"description": "Grant access to LuCI app FakeHTTP",
		"read": {
			"uci": [ "fakehttp" ],
			"ubus": {
				"service": [ "list" ]
			},
			"file": {
				"/usr/libexec/fakehttp-logread": [ "exec" ],
				"/usr/libexec/fakehttp-cron-status": [ "exec" ]
			}
		},
		"write": {
			"uci": [ "fakehttp" ],
			"file": {
				"/etc/init.d/fakehttp": [ "exec" ]
			}
		}
	}
}
